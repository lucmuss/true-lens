# Project display name used in templates, page titles, and emails.
PROJECT_NAME="TrueLens"
# Slug used for internal naming and service identifiers.
PROJECT_SLUG="true_lens"
# Public base URL used for absolute links and redirects.
APP_PUBLIC_URL="http://localhost:18087"

# Runtime mode (development or production) controlling security defaults.
DJANGO_ENV="development"
# Enables Django debug output; keep false in production.
DJANGO_DEBUG="true"
# Secret key for Django cryptographic signing.
DJANGO_SECRET_KEY="replace-me"
# Allowed hostnames and IPs accepted by Django.
DJANGO_ALLOWED_HOSTS="localhost,127.0.0.1"
# Trusted origins allowed to send CSRF-protected requests.
DJANGO_CSRF_TRUSTED_ORIGINS="http://localhost:18087"
# Controls HTTP->HTTPS redirect behavior.
DJANGO_SECURE_SSL_REDIRECT="false"
# Marks session cookie as secure-only.
DJANGO_SESSION_COOKIE_SECURE="false"
# Marks CSRF cookie as secure-only.
DJANGO_CSRF_COOKIE_SECURE="false"
# Optional HSTS duration in seconds.
DJANGO_SECURE_HSTS_SECONDS="0"
# Include subdomains in HSTS policy.
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS="false"
# Advertise HSTS preload eligibility.
DJANGO_SECURE_HSTS_PRELOAD="false"
# Django site id used by allauth/sites framework.
DJANGO_SITE_ID="1"
# Time zone for date/time rendering and retention rules.
DJANGO_TIME_ZONE="Europe/Berlin"
# Language code for i18n defaults.
DJANGO_LANGUAGE_CODE="de-de"
# Global logging verbosity.
DJANGO_LOG_LEVEL="INFO"
# Toggle static manifest hashing for immutable asset caching.
STATICFILES_USE_MANIFEST="false"

# Full database URL for primary PostgreSQL connection.
DATABASE_URL="postgresql://true_lens:replace-me@postgres:5432/true_lens"
# Requires SSL mode when connecting to PostgreSQL.
DATABASE_SSL_REQUIRE="false"
# Connection keepalive age in seconds.
DB_CONN_MAX_AGE="60"

# Main email delivery mode: smtp, resend, file, console, locmem, custom.
EMAIL_DELIVERY_MODE="file"
# File backend output path used when mode=file.
EMAIL_FILE_PATH="/tmp/true-lens-mails"
# Custom backend import path used when mode=custom.
DJANGO_EMAIL_BACKEND=""
# SMTP host used when mode=smtp.
DJANGO_EMAIL_HOST="smtp.gmail.com"
# SMTP port used when mode=smtp.
DJANGO_EMAIL_PORT="587"
# SMTP username used when mode=smtp.
DJANGO_EMAIL_HOST_USER=""
# SMTP password used when mode=smtp.
DJANGO_EMAIL_HOST_PASSWORD=""
# Enables STARTTLS for SMTP connections.
DJANGO_EMAIL_USE_TLS="true"
# Enables implicit SSL for SMTP connections.
DJANGO_EMAIL_USE_SSL="false"
# Email network timeout in seconds.
DJANGO_EMAIL_TIMEOUT="15"
# Default sender address for transactional emails.
DJANGO_DEFAULT_FROM_EMAIL="noreply@example.local"
# Sender address used for Django server error mails.
DJANGO_SERVER_EMAIL="noreply@example.local"

# Enables Resend integration when API key exists.
USE_RESEND="false"
# Resend API key for direct transactional email delivery.
RESEND_API_KEY=""
# Sender email identity for Resend API calls.
RESEND_FROM_EMAIL=""

# Public Stripe key exposed to checkout UI.
STRIPE_PUBLIC_KEY=""
# Secret Stripe key used for checkout session creation.
STRIPE_SECRET_KEY=""
# Stripe webhook signature secret for event verification.
STRIPE_WEBHOOK_SECRET=""
# Currency used for credit checkout products.
STRIPE_DEFAULT_CURRENCY="eur"
# Price per single credit in major currency units.
CREDIT_PRICE_EUR="1.00"

# Optional Sentry DSN for error reporting.
SENTRY_DSN=""
# Explicit Sentry environment label.
SENTRY_ENVIRONMENT=""
# Sentry release identifier.
SENTRY_RELEASE=""
# Enables Sentry PII collection when true.
SENTRY_SEND_PII="false"
# Trace sample rate for Sentry performance monitoring.
SENTRY_TRACES_SAMPLE_RATE="0.05"
# Profile sample rate for Sentry profiling.
SENTRY_PROFILES_SAMPLE_RATE="0.0"

# Search step timeout in seconds enforced server-side.
SEARCH_STEP_TIMEOUT_SECONDS="30"
# Max time a resolved profile can be viewed per lookup.
PROFILE_VIEW_WINDOW_SECONDS="180"
# Anonymous lookup quota per IP and day.
ANON_LOOKUPS_PER_DAY="1"
# Authenticated lookup quota per recruiter and day.
AUTH_LOOKUPS_PER_DAY="1"
# New candidate creation quota per recruiter and week.
AUTH_NEW_RECORDS_PER_WEEK="1"
# Cooldown in days between recruiter voting actions.
VOTE_COOLDOWN_DAYS="3"
# Vote retention period in years before exclusion.
VOTE_RETENTION_YEARS="5"

# Enables global rate limiting decorators.
RATELIMIT_ENABLE="true"
# Default fallback rate limit for protected endpoints.
RATELIMIT_DEFAULT_RATE="30/h"
# Enables startup preflight checks for configured external providers.
EXTERNAL_SERVICES_CHECK_ON_START=""
# When true, startup fails if at least one preflight check fails.
EXTERNAL_SERVICES_CHECK_STRICT=""
# Timeout in seconds per external provider preflight check.
EXTERNAL_SERVICES_CHECK_TIMEOUT="10"
# JS API gate token time-to-live in seconds.
API_JS_GATE_TTL_SECONDS="120"
# JS gate hash rotation interval in seconds.
API_JS_GATE_ROTATION_SECONDS="15"
# Number of violations before temporary IP ban.
IP_BAN_THRESHOLD="8"
# Temporary ban duration in minutes.
IP_BAN_MINUTES="60"

# Feature switch for multi-node replication logic.
REPLICATION_ENABLED="true"
# Desired replication factor across nodes.
REPLICATION_FACTOR="3"
# Shared secret for internal replication signatures.
REPLICATION_SHARED_SECRET="replace-me"
# Coordinator liveness timeout before election.
COORDINATOR_DOWN_THRESHOLD_SECONDS="3600"

# Google Places API key for country/region/city autocomplete.
GOOGLE_PLACES_API_KEY=""

# Google social login client id for allauth provider config.
SOCIALACCOUNT_GOOGLE_CLIENT_ID=""
# Google social login secret for allauth provider config.
SOCIALACCOUNT_GOOGLE_SECRET=""
# GitHub social login client id for allauth provider config.
SOCIALACCOUNT_GITHUB_CLIENT_ID=""
# GitHub social login secret for allauth provider config.
SOCIALACCOUNT_GITHUB_SECRET=""

# Bootstrap superuser email created by bootstrap scripts.
DJANGO_SUPERUSER_EMAIL="admin@example.local"
# Bootstrap superuser password created by bootstrap scripts.
DJANGO_SUPERUSER_PASSWORD="replace-me"
# Bootstrap superuser first name for admin profile.
DJANGO_SUPERUSER_FIRST_NAME="Admin"
# Bootstrap superuser last name for admin profile.
DJANGO_SUPERUSER_LAST_NAME="Coordinator"
# Bootstrap superuser display name for UI contexts.
DJANGO_SUPERUSER_DISPLAY_NAME="System Coordinator"
